{
  "manifest_version": 3,
  "name": "GY-NEXUS China Shorts Account Connector",
  "version": "1.2.0",
  "description": "Connects the owner's existing Edge login to GY-NEXUS and returns visible Douyin/Xiaohongshu search-card metadata with diagnostics.",
  "permissions": [
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*.douyin.com/*",
    "https://*.xiaohongshu.com/*",
    "https://gy-nexus-zfpq.vercel.app/*",
    "https://app.gywealthlab.com/*",
    "https://ai.gylabs.kr/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "GY China Connector",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gy-nexus-zfpq.vercel.app/*",
        "https://app.gywealthlab.com/*",
        "https://ai.gylabs.kr/*",
        "http://localhost:3000/*"
      ],
      "js": [
        "gy-bridge.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://*.douyin.com/*",
        "https://*.xiaohongshu.com/*"
      ],
      "js": [
        "platform-scraper.js"
      ],
      "run_at": "document_idle"
    }
  ]
}