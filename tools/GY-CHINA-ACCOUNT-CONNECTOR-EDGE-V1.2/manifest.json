{
  "manifest_version": 3,
  "name": "GY-NEXUS China Shorts Account Connector",
  "version": "1.2.0",
  "description": "Connects the dedicated GY-NEXUS China Video Lab to visible Douyin and Xiaohongshu search cards using the existing Edge login.",
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "https://www.douyin.com/*",
    "https://www.xiaohongshu.com/*",
    "https://gy-nexus-zfpq.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gy-nexus-zfpq.vercel.app/*",
        "http://localhost:3000/*"
      ],
      "js": [
        "gy-bridge.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.douyin.com/*",
        "https://www.xiaohongshu.com/*"
      ],
      "js": [
        "platform-scraper.js"
      ],
      "run_at": "document_idle"
    }
  ]
}