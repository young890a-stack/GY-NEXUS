# =========================================================
# GY-NEXUS · PRODUCTION 2.0
# 실제 값은 .env.local 또는 Vercel Environment Variables에만 입력하세요.
# 이 파일에는 비밀값을 절대 넣지 마세요.
# =========================================================

# Core · 필수
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OWNER_EMAIL=
# 선택: 비워두면 SUPABASE_SERVICE_ROLE_KEY에서 연동 토큰용 키를 안전하게 파생합니다.
CONNECTION_ENCRYPTION_KEY=

# AI Council
OPENAI_API_KEY=
OPENAI_STRATEGY_MODEL=gpt-5.6-terra
OPENAI_MEMBER_MODEL=gpt-5.6-luna
OPENAI_QUALITY_MODEL=gpt-5.6-sol
GEMINI_API_KEY=
GEMINI_REVIEW_MODEL=gemini-3.5-flash

# Creative Studio
OPENAI_IMAGE_MODEL=gpt-image-2
RUNWAYML_API_SECRET=
RUNWAY_VIDEO_MODEL=gen4.5
CREATIVE_STORAGE_BUCKET=creative-assets
SHORTS_QUALITY_THRESHOLD=85
SHORTS_MAX_IMAGE_RETRIES=2
VIDEO_WORKER_URL=
VIDEO_WORKER_SECRET=

# Google 공통 OAuth · 서비스별 전용 값이 없을 때 사용
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=

# Blogger
BLOGGER_CLIENT_ID=
BLOGGER_CLIENT_SECRET=
# 선택: 비우면 NEXT_PUBLIC_SITE_URL + /api/connections/blogger/callback을 사용합니다.
BLOGGER_REDIRECT_URI=
BLOGGER_BLOG_ID=

# Search Console / Analytics
SEARCH_CONSOLE_CLIENT_ID=
SEARCH_CONSOLE_CLIENT_SECRET=
SEARCH_CONSOLE_REDIRECT_URI=
SEARCH_CONSOLE_SITE_URL=
GA4_PROPERTY_ID=
GA4_MEASUREMENT_ID=

# Naver · 현재는 로그인 및 게시 패키지 생성 기반
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
# 선택: 비우면 NEXT_PUBLIC_SITE_URL + /api/connections/naver/callback을 사용합니다.
NAVER_REDIRECT_URI=

# Affiliate · 공식 파트너 권한이 있을 때만 연결
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
# 선택: 쿠팡 파트너스에 등록한 채널 추적 ID
COUPANG_SUB_ID=
# 선택: 기본값 512x512
COUPANG_IMAGE_SIZE=512x512
# Temu는 Affiliate 대시보드의 공유 링크 등록 방식입니다. ID는 계정 표시용 선택값입니다.
TEMU_APP_KEY=
TEMU_AFFILIATE_ID=
# 이전 버전 호환용. 새 소싱센터에서는 필요하지 않습니다.
TEMU_AFFILIATE_LINK_TEMPLATE=

# Optional publishers / automation
WORDPRESS_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
AUTOMATION_WEBHOOK_URL=
AUTOMATION_WEBHOOK_SECRET=
AUTOMATION_MAX_JOBS_PER_RUN=3

# Revenue / Learning defaults
REVENUE_DEFAULT_CURRENCY=KRW
LEARNING_MIN_SAMPLE_SIZE=10
FORECAST_MODEL_VERSION=s6-baseline-v1
