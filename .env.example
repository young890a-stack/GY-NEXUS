# =========================================
# GY-NEXUS 운영형 기반
# 실제 값은 .env.local에만 입력하세요.
# =========================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
CONNECTION_ENCRYPTION_KEY=

# YouTube OAuth
# http://localhost:3000/api/connections/youtube/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Google Blogger OAuth
# 같은 Google OAuth 클라이언트를 재사용할 수 있습니다.
# http://localhost:3000/api/connections/blogger/callback
BLOGGER_CLIENT_ID=
BLOGGER_CLIENT_SECRET=
# 블로그가 여러 개일 때만 입력
BLOGGER_BLOG_ID=

# Naver Login OAuth
# http://localhost:3000/api/connections/naver/callback
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Temu Affiliate는 상품별 제휴 URL 저장이 기본입니다.
TEMU_AFFILIATE_ID=
TEMU_AFFILIATE_LINK_TEMPLATE=

# 선택 연결
AUTOMATION_WEBHOOK_URL=
AUTOMATION_WEBHOOK_SECRET=
WORDPRESS_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# Sprint 4 · Creative Studio
OPENAI_IMAGE_MODEL=gpt-image-1
RUNWAYML_API_SECRET=
RUNWAY_VIDEO_MODEL=gen4.5
CREATIVE_STORAGE_BUCKET=creative-assets
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# Sprint 5 · Publishing Center
# Blogger는 YOUTUBE_CLIENT_ID/SECRET을 재사용할 수 있습니다.
BLOGGER_CLIENT_ID=
BLOGGER_CLIENT_SECRET=
BLOGGER_BLOG_ID=

# WordPress Application Password 방식
WORDPRESS_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# Make / Zapier / n8n
AUTOMATION_WEBHOOK_URL=
AUTOMATION_WEBHOOK_SECRET=

# Sprint 6 자동 운영 엔진
# 실제 공개 전 기본값은 Blogger 초안 / YouTube 비공개를 권장합니다.
AUTOMATION_MAX_JOBS_PER_RUN=3

# =========================================
# Sprint 8 · Google Search Console
# 기존 Blogger/YouTube OAuth를 재사용할 수 있습니다.
# 별도 값을 넣으면 이 값이 우선됩니다.
# =========================================
SEARCH_CONSOLE_CLIENT_ID=
SEARCH_CONSOLE_CLIENT_SECRET=
SEARCH_CONSOLE_SITE_URL=

# =========================
# Sprint 9 · Google Growth Intelligence
# =========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SEARCH_CONSOLE_SITE_URL=https://gywealthlab.blogspot.com/
GA4_PROPERTY_ID=543105479
GA4_MEASUREMENT_ID=G-MSD45HMDJZ
CONNECTION_ENCRYPTION_KEY=change-this-to-a-long-random-secret-at-least-32-characters

# =========================
# Sprint 10 · AI Company OS
# =========================
# Dream Y 대표 브리핑은 OPENAI_API_KEY를 재사용합니다.
# Google OAuth 토큰 암호화를 위해 32자 이상의 임의 문자열을 사용하세요.
CONNECTION_ENCRYPTION_KEY=

# Creative Studio Pro final MP4 renderer (Render/Railway worker)
VIDEO_WORKER_URL=
VIDEO_WORKER_SECRET=
